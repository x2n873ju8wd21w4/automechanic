# ==== LLM дистилляция (OpenAI-совместимый endpoint) ==========================
# NVIDIA NIM (build.nvidia.com, бесплатные ключи nvapi-...)
DISTILL_BASE_URL=https://integrate.api.nvidia.com/v1
DISTILL_API_KEY=
# проверено 2026-07-10: minimax-m2.7 и nemotron-3-super живы;
# qwen3-coder-480b и glm-5.1 на NIM уже EOL (410) — модели там смертны!
DISTILL_MODEL=minimaxai/minimax-m2.7

# Каскад (опционально): эндпоинты через ";", внутри base_url|ENV_ключа|model.
# "none" = без ключа. При 429/402/410/5xx каскад идёт к следующему.
# Последним можно повесить гейтвей веб-чатов (clawbot) через туннель.
# DISTILL_ENDPOINTS=https://integrate.api.nvidia.com/v1|NIM_API_KEY|minimaxai/minimax-m2.7;https://api.groq.com/openai/v1|GROQ_API_KEY|llama-3.3-70b-versatile;https://api.cerebras.ai/v1|CEREBRAS_API_KEY|qwen-3-235b-a22b-instruct-2507;https://text.pollinations.ai/openai|none|openai;https://tunnel-домашнего-сервера/v1|CHAT_GATEWAY_KEY|qwen-chat
# Альтернативы (см. docs/free-tier-map.md): Groq, Cerebras, Gemini, OpenRouter :free,
# локальный free-claude-code gateway: DISTILL_BASE_URL=http://localhost:8080/v1

# ==== Эмбеддинги (bge-m3, 1024d, мультиязычная) ===============================
# Провайдеры по порядку: NIM (если ключ задан) -> Cloudflare -> локальная модель.
# Факты 2026-07-10: baai/bge-m3 на NIM отдаёт 500 (сломан); nv-embedqa-e5-v5
# работает (1024d), но англо-центричен. Primary: локальный bge-m3
# (pip install -r requirements-embed-local.txt) либо Cloudflare @cf/baai/bge-m3.
EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
EMBED_API_KEY=
EMBED_MODEL=baai/bge-m3
EMBED_DIM=1024

# Cloudflare Workers AI — вторая реплика той же модели (10k neurons/день free)
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_EMBED_MODEL=@cf/baai/bge-m3

# Свой эмбеддинг-сервер (bge-m3 на Kaggle T4, kaggle/embedding_server.py) —
# если задан, идёт первым в цепочке
EMBED_REMOTE_URL=
EMBED_REMOTE_KEY=

# ==== YouTube =================================================================
# YOUTUBE_API_KEY обязателен для discovery в облачном CI (официальный API,
# DC IP не банится). Без ключа discovery работает только с чистого IP (yt-dlp).
YOUTUBE_API_KEY=
SUB_LANGS=ru,uk,en,de,es,pt,pl,tr
YTDLP_SLEEP_SECONDS=8

# ==== Транскрипты: цепочка провайдеров (для облачного CI без чистого IP) =====
# ytdlp     - первым; на DC IP быстро фейлится и цепочка идёт дальше;
#             с YTDLP_PROXY (residential) - ОСНОВНОЙ путь: титры ~100KB =>
#             1 GB прокси-трафика ~ 5-10 тыс. видео за $1-3
# invidious - бесплатный бонус; проверено 2026-07-10: зеркала листят титры,
#             но тела часто пустые (YouTube режет их бекенды) - цепочка
#             это переживает; живые инстансы искать на https://api.invidious.io
# supadata  - https://supadata.ai, стабильный transcript-API, free tier ~100
#             запросов для смоука, дальше платно-дешево (ключ ниже)
SUBTITLE_PROVIDERS=ytdlp,invidious,supadata
INVIDIOUS_INSTANCES=https://inv.nadeko.net,https://yewtu.be,https://invidious.nerdvpn.de,https://iv.melmac.space,https://invidious.f5.si
SUPADATA_API_KEY=
# residential-прокси для yt-dlp в CI (решает 429 радикально, ~$1-3/GB, напр. webshare.io)
YTDLP_PROXY=

# ==== ASR (видео без титров: CarCareKiosk и т.п.) =============================
# Цепочка: remote (Kaggle T4 /transcribe, whisper large-v3) -> cloudflare
# (@cf/openai/whisper, free) -> local (faster-whisper; модель ниже).
# remote использует EMBED_REMOTE_URL/KEY (тот же Kaggle-сервер).
ASR_PROVIDERS=remote,cloudflare,local
ASR_LOCAL_MODEL=small

# ==== CI-аккаунты: самораспределение через claim + бюджет минут ==============
# Метка аккаунта (a|b|c...) — под ней считается бюджет и подписываются claim'ы.
CI_ACCOUNT=solo
# Месячный лимит минут аккаунта; этап тихо выходит, если исчерпан.
CI_MONTHLY_MINUTES=6000
# Где хранить остаток минут: ado (помесячный work item-леджер, Feature.Effort —
# стейт в самом ADO, без внешних зависимостей) | r2 (файл в бакете). По умолч. ado.
CI_BUDGET_STORE=ado
# JSON-массив аккаунтов CircleCI для диспетчера (в ADO — из variable group):
# [{"name":"acc-a","circleci_token":"...","circleci_project_slug":"circleci/<org>/<proj>","circleci_definition_id":"<uuid>"}]
CI_ACCOUNTS_JSON=
# PARTITION оставлен опцией (even|odd), по умолчанию не делим — полагаемся на claim.
PARTITION=

# ==== Azure DevOps (тикетная система конвейера) ===============================
# Кастомный процесс AutoMechanikBoard: Task (видео/тред) со состояниями
# New -> ReadyForFilter -> ReadyForEmbeding -> Closed (Removed = брак/offtopic);
# Epic (канал/форум); поле Custom.url = ссылка на источник (дедуп/дельта-поиск).
ADO_ORG=gpsgroupagent12
ADO_PROJECT=AutoMechanic
ADO_PAT=
ADO_WORKITEM_TYPE=Task
ADO_CHANNEL_TYPE=Epic
ADO_URL_FIELD=Custom.url

# ==== Архив: S3-совместимое хранилище (Cloudflare R2 / Backblaze B2) =========
S3_ENDPOINT=
S3_KEY=
S3_SECRET=
S3_BUCKET=automech-archive

# ==== Векторная реплика: Qdrant Cloud (free 1GB) ==============================
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cases

# ==== Бекэнд (backend/app.py) =================================================
# Если задан — API требует заголовок X-Api-Key (мобилка передаёт из dart-define)
BACKEND_API_KEY=
# Каскад LLM для RAG-ответов мобилке (формат как DISTILL_ENDPOINTS).
# По умолчанию Pollinations (без ключа, проверен). Сильнее: NIM/гейтвей чатов.
# ANSWER_ENDPOINTS=https://integrate.api.nvidia.com/v1|NIM_API_KEY|minimaxai/minimax-m2.7;https://text.pollinations.ai/openai|none|openai
